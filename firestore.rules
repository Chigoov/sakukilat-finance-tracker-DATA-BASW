rules_version = '2';

// SakuKilat — Firestore Security Rules
// ------------------------------------
// Isolasi data ketat per-user. Setiap dokumen di bawah users/{userId}/**
// hanya boleh dibaca/ditulis oleh pemiliknya — bahkan setelah login,
// pengguna lain tidak dapat menyentuh data ini.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
